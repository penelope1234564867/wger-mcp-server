# wger API 配置（可选，按需配置）
# wger 实例地址，默认官方实例。自托管时改成自己的地址
WGER_API_URL=https://wger.de
# API 版本。默认 v2（wger.de 的 v1 前有 Anubis 反爬，v2 被放行）
WGER_API_VERSION=v2
# wger API Token —— 登录类工具（体重/营养计划/用户档案）需要
# 登录 wger.de 后到 https://wger.de/en/user/api-key 生成
WGER_API_TOKEN=
# 请求超时（秒）
WGER_TIMEOUT=30
# 列表缓存 TTL（秒）
WGER_CACHE_TTL=3600
